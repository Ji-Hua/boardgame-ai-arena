FROM python:3.12-slim

WORKDIR /app

# Install Python deps
RUN pip install --no-cache-dir fastapi "uvicorn[standard]" pydantic

# Copy agent service source
# The agents/ directory is the top-level package (imports: agents.agent_service.*)
COPY agents/ /app/agents/

EXPOSE 8090

CMD ["uvicorn", "agents.agent_service.server:app", "--host", "0.0.0.0", "--port", "8090"]
